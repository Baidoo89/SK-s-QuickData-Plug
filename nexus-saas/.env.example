# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# App URLs
NEXTAUTH_URL="https://your-domain.com"
APP_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Auth/session secrets
NEXTAUTH_SECRET="replace-with-strong-random-secret"
AUTH_SECRET="replace-with-strong-random-secret"

# Email delivery via Resend
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Your App <noreply@your-domain.com>"

# Public support contact. Use international format, e.g. 233XXXXXXXXX.
NEXT_PUBLIC_SUPPORT_WHATSAPP_NUMBER="233XXXXXXXXX"

# Platform SaaS subscription billing. This is your Paystack account.
PAYSTACK_SECRET_KEY="sk_live_or_test_xxxxxxxxxxxxxxxxx"
PAYSTACK_SUBSCRIPTION_SECRET_KEY="sk_live_or_test_subscription_xxxxxxxxx"

# Subscriber Paystack secret encryption.
PAYMENT_SETTINGS_ENCRYPTION_KEY="replace-with-strong-random-secret"

# Optional wallet fallback key. Storefront customer funds should normally use
# each subscriber's own Paystack keys saved in subscriber payment settings.
# PAYSTACK_WALLET_SECRET_KEY="sk_live_or_test_wallet_xxxxxxxxx"

# Manual-first dispatch is recommended for launch testing.
DISPATCH_MODE="MANUAL"
# DISPATCH_API_NETWORKS="MTN,TELECEL,AIRTELTIGO"
# DISPATCH_PROVIDER_NAME="Provider"
# PROVIDER_ORDER_URL="https://provider.example.com/orders"
# PROVIDER_API_KEY="replace-with-provider-secret"
# PROVIDER_WEBHOOK_SECRET="replace-with-webhook-secret"
# PROVIDER_WEBHOOK_HMAC_SECRET="replace-with-hmac-secret"

# Optional operations tuning
API_ORDER_RATE_LIMIT_PER_MINUTE="60"
CRON_SECRET="replace-with-strong-random-secret"
STOREFRONT_PAYMENT_PENDING_TIMEOUT_MINUTES="30"
DISPATCH_RETRY_MAX_ATTEMPTS="3"
DISPATCH_RETRY_BACKOFF_SECONDS="30"
DISPATCH_HEALTH_PENDING_AGE_MINUTES="30"
DISPATCH_HEALTH_ALERT_FAIL_THRESHOLD="5"
DISPATCH_HEALTH_ALERT_STALE_THRESHOLD="10"

# Optional one-time launch owner seed
SEED_SUPERADMIN_EMAIL="admin@your-domain.com"
SEED_SUPERADMIN_NAME="App Super Admin"
SEED_SUPERADMIN_PASSWORD="replace-with-strong-password"
